<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent"
                                                   tools:context=".HomePageActivity">

    <!-- ScrollView to enable scrolling -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <!-- Settings Button -->
            <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_settings_icon"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="settings"
                    android:padding="8dp"
                    android:layout_gravity="start" /> <!-- Align to start (left) -->

            <!-- Enrolled Courses Section -->
            <TextView
                    android:id="@+id/tv_enrolled_courses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enrolled Courses"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

            <!-- Enrolled Course 1 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp">

                <ImageView
                        android:id="@+id/img_enrolled_course_1"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:src="@drawable/courseimage1"
                        android:layout_margin="10dp"
                        android:contentDescription="course_image" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product and Service details"
                        android:layout_marginStart="10dp" />

                <ProgressBar
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="100"
                        android:layout_margin="10dp" />
            </LinearLayout>

            <!-- Enrolled Course 2 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp">

                <ImageView
                        android:id="@+id/img_enrolled_course_2"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:src="@drawable/courseimage3"
                        android:layout_margin="10dp"
                        android:contentDescription="course_image" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health and Safety"
                        android:layout_marginStart="10dp" />

                <ProgressBar
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="100"
                        android:layout_margin="10dp" />
            </LinearLayout>

            <!-- Available Courses Section -->
            <TextView
                    android:id="@+id/tv_available_courses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available Courses"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

            <!-- Scrollable Available Courses -->
            <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:padding="10dp">

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <ImageView
                            android:layout_width="127dp"
                            android:layout_height="127dp"
                            android:src="@drawable/course_placeholder"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/course_image" />

                    <ImageView
                            android:layout_width="127dp"
                            android:layout_height="127dp"
                            android:src="@drawable/course_placeholder"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/course_image" />

                    <ImageView
                            android:layout_width="127dp"
                            android:layout_height="127dp"
                            android:src="@drawable/course_placeholder"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/course_image" />

                    <ImageView
                            android:layout_width="127dp"
                            android:layout_height="127dp"
                            android:src="@drawable/course_placeholder"
                            android:contentDescription="@string/course_image" />

                    <!-- Add More Courses Button -->
                    <ImageButton
                            android:id="@+id/btn_add_course"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/add_circle"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="more_courses"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Helpful Tips Section -->
            <TextView
                    android:id="@+id/tv_helpful_tips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Helpful Tips"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

            <!-- Helpful Tip 1 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:padding="10dp">

                <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_user_placeholder"
                        android:layout_marginEnd="8dp" />

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec ut posuere sapien, ac tempor urna."
                        android:layout_weight="1" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 20"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Helpful Tip 2 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:padding="10dp">

                <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_user_placeholder"
                        android:layout_marginEnd="8dp" />

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec ut posuere sapien, ac tempor urna."
                        android:layout_weight="1" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 5"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
